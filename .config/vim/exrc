vim9script

filetype plugin indent on
syntax on

packadd comment

if has("win32")
    set guicursor=a:block-blinkon0
endif

set belloff=all
set fillchars=vert:│
set hlsearch
set ignorecase
set incsearch
set laststatus=0
set noswapfile
set nowrap
set shiftwidth=4 
set smartcase
set smarttab 
set tabstop=4 #ucan set sw=0 to inherit from ts

g:mapleader = " "
nnoremap <leader>w <Cmd>update<CR>
nnoremap <leader>te :tabe<space>
nnoremap <leader>bd <Cmd>bdelete<CR>
nnoremap <leader>bs <Cmd>ls<CR>:b<space>
nnoremap <leader>y :%y+<CR>
xnoremap <leader>y "+y
nnoremap <Esc><Esc> <Cmd>nohlsearch<CR>

set termguicolors
colorscheme quiet
hi Normal guibg=#181818 #gruber
hi VertSplit guibg=bg
hi Special guifg=#d02b61
hi String guifg=#5688af

#cavemens
#autopairs
inoremap (<CR> (<CR>)<Esc>O
inoremap [<CR> [<CR>]<Esc>O
inoremap {<CR> {<CR>}<Esc>O
