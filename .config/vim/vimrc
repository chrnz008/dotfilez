vim9script

set guioptions+=M # :h go-M

filetype plugin indent on
syntax on

colorscheme quiet
set belloff=all
set cursorline
set cursorlineopt=number
set fillchars+=vert:│
set hlsearch
set ignorecase
set incsearch
set laststatus=0
set noswapfile
set nowrap
set shiftwidth=4
set smartcase
set smarttab
set tabstop=4
set termguicolors
